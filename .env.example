# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore).

# e-conomic REST API (Visma e-conomic — invoices, customers, payments)
# Setup: In e-conomic → Settings → Extensions → Apps → New App (Read-only role)
#   1. Copy the App Secret Token → ECONOMIC_APP_SECRET
#   2. Open the Installation URL while logged in, click "Add app"
#   3. Copy the Agreement Grant Token → ECONOMIC_GRANT_TOKEN
ECONOMIC_APP_SECRET=
ECONOMIC_GRANT_TOKEN=

# WooCommerce REST API (optional — for Inventory Intelligence)
WOOCOMMERCE_URL=
WOOCOMMERCE_KEY=
WOOCOMMERCE_SECRET=

# Etsy Open API v3 (optional — free, 10K req/day)
ETSY_API_KEY=

# SerpAPI (optional — $50/mo for 5000 searches)
SERPAPI_KEY=
